<Window x:Class="ClaudeUsageTracker.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Claude Usage Tracker"
        Width="860" Height="600"
        MinWidth="720" MinHeight="560"
        Background="#0f0f0f"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">

    <Window.Resources>
        <SolidColorBrush x:Key="TxtHighlight" Color="#f5f5f5"/>
        <SolidColorBrush x:Key="TxtSub" Color="#888888"/>

        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Background" Value="#262626"/>
            <Setter Property="Foreground" Value="#e8e8e8"/>
            <Setter Property="BorderBrush" Value="#2a2a2a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#1e1e1e"/>
            <Setter Property="BorderBrush" Value="#2a2a2a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14"/>
        </Style>

        <Style x:Key="Sec" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="Big" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#f5f5f5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>      <!-- Header -->
            <RowDefinition Height="3*"/>        <!-- Hero row -->
            <RowDefinition Height="8"/>
            <RowDefinition Height="2*"/>        <!-- Weekly cards -->
            <RowDefinition Height="8"/>
            <RowDefinition Height="2*"/>        <!-- Delta chart -->
            <RowDefinition Height="Auto"/>      <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Claude Usage" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TxtHighlight}" VerticalAlignment="Center"/>

            <Border Grid.Column="1" Margin="12,0,0,0" CornerRadius="4" Padding="8,3" Background="#1a1a1a"
                    VerticalAlignment="Center">
                <TextBlock x:Name="StatusLabel" Text="Waiting for session key..." FontSize="11"
                           Foreground="{StaticResource TxtSub}" FontWeight="SemiBold"/>
            </Border>

            <!-- Update notification button (hidden by default) -->
            <Button Grid.Column="2" x:Name="UpdateBtn" Visibility="Collapsed"
                    Click="UpdateBtn_Click" Cursor="Hand" HorizontalAlignment="Right" Margin="0,0,12,0"
                    BorderThickness="0" Padding="10,5">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#1a3a1a" CornerRadius="6" BorderBrush="#4ade80"
                                BorderThickness="1" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="UpdateBtnIcon" Text="⬆" FontSize="12" Foreground="#4ade80"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock x:Name="UpdateBtnText" Text="업데이트 가능" FontSize="11"
                                           FontWeight="SemiBold" Foreground="#4ade80" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2a4a2a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Grid.Column="3" x:Name="OpenClaudeBtn" Content="💬 Claude"
                    Style="{StaticResource Btn}" Click="OpenClaudeBtn_Click" Margin="0,0,8,0"/>

            <Button Grid.Column="4" x:Name="CheckUpdateBtn" Content="🔄 Update"
                    Style="{StaticResource Btn}" Click="CheckUpdateBtn_Click" Margin="0,0,8,0"/>

            <Button Grid.Column="5" x:Name="TopMostBtn" Content="📌" ToolTip="항상 위"
                    Style="{StaticResource Btn}" Click="TopMostBtn_Click" Margin="0,0,8,0"/>

            <Button Grid.Column="6" x:Name="RefreshBtn" Content="↻ Refresh"
                    Style="{StaticResource Btn}" Click="RefreshBtn_Click" Margin="0,0,8,0"/>

            <Button Grid.Column="7" x:Name="LoginBtn" Content="Login"
                    Style="{StaticResource Btn}" Click="LoginBtn_Click"/>
        </Grid>

        <!-- ═══ HERO ROW: 5-Hour Session + Extra Usage ═══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- 5-Hour Session -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <TextBlock Text="5-HOUR SESSION" Style="{StaticResource Sec}"/>
                        <TextBlock x:Name="SessionResetAtLabel" Text="Resets at --"
                                   FontSize="10" Foreground="#888" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Usage Ring -->
                        <Grid Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Viewbox Stretch="Uniform" MaxWidth="150" MaxHeight="150">
                                <Canvas Width="200" Height="200">
                                    <Ellipse Width="172" Height="172" Canvas.Left="14" Canvas.Top="14"
                                             Stroke="#262626" StrokeThickness="14" Fill="Transparent"/>
                                    <Path x:Name="UsageRingPath" StrokeThickness="14"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                        <Path.Stroke>
                                            <SolidColorBrush x:Name="UsageRingBrush" Color="#4ade80"/>
                                        </Path.Stroke>
                                        <Path.Data>
                                            <PathGeometry>
                                                <PathFigure x:Name="UsageRingFigure" StartPoint="100,14">
                                                    <ArcSegment x:Name="UsageRingArc" Point="100,14"
                                                                Size="86,86" IsLargeArc="False"
                                                                SweepDirection="Clockwise"/>
                                                </PathFigure>
                                            </PathGeometry>
                                        </Path.Data>
                                    </Path>
                                </Canvas>
                            </Viewbox>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock x:Name="UsagePctText" Text="0%" Style="{StaticResource Big}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Used" FontSize="10" Foreground="#888" HorizontalAlignment="Center"/>
                                <TextBlock Text="of session" FontSize="9" Foreground="#666"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <!-- Time Left Ring -->
                        <Grid Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Viewbox Stretch="Uniform" MaxWidth="150" MaxHeight="150">
                                <Canvas Width="200" Height="200">
                                    <Ellipse Width="172" Height="172" Canvas.Left="14" Canvas.Top="14"
                                             Stroke="#262626" StrokeThickness="14" Fill="Transparent"/>
                                    <Path x:Name="TimeRingPath" StrokeThickness="14"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                        <Path.Stroke>
                                            <SolidColorBrush x:Name="TimeRingBrush" Color="#60a5fa"/>
                                        </Path.Stroke>
                                        <Path.Data>
                                            <PathGeometry>
                                                <PathFigure x:Name="TimeRingFigure" StartPoint="100,14">
                                                    <ArcSegment x:Name="TimeRingArc" Point="100,14"
                                                                Size="86,86" IsLargeArc="False"
                                                                SweepDirection="Clockwise"/>
                                                </PathFigure>
                                            </PathGeometry>
                                        </Path.Data>
                                    </Path>
                                </Canvas>
                            </Viewbox>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock x:Name="TimeLeftText" Text="--" Style="{StaticResource Big}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Time Left" FontSize="10" Foreground="#888"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TimeLeftPctText" Text="of 5h left" FontSize="9"
                                           Foreground="#666" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <!-- Extra Usage -->
            <Border Grid.Column="2" x:Name="ExtraCard" Style="{StaticResource Card}">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="EXTRA USAGE" Style="{StaticResource Sec}"/>
                    <TextBlock x:Name="ExtraUsedText" Text="$0.00" Style="{StaticResource Big}"/>
                    <TextBlock x:Name="ExtraLimitText" Text="of $0.00" FontSize="11"
                               Foreground="#888" Margin="0,2,0,8"/>
                    <Grid Height="6" Margin="0,0,0,6">
                        <Border Background="#262626" CornerRadius="3"/>
                        <Border x:Name="ExtraBar" Background="#4ade80" CornerRadius="3"
                                HorizontalAlignment="Left" Width="0"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="ExtraPctText" Text="0%" FontSize="12" FontWeight="Bold"
                                   Foreground="#e8e8e8"/>
                        <TextBlock Text="  Monthly" FontSize="10" Foreground="#888" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="ExtraDisabledText" Text="Disabled" FontSize="11"
                               Foreground="#f87171" Visibility="Collapsed" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══ WEEKLY CARDS ═══ -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- All Models -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="WEEKLY · ALL MODELS" Style="{StaticResource Sec}"/>
                    <TextBlock Grid.Row="1" x:Name="WeekAllPctText" Text="0%" Style="{StaticResource Big}"
                               Margin="0,0,0,8"/>
                    <Grid Grid.Row="2" Height="18" VerticalAlignment="Center" Margin="0,0,0,6">
                        <Grid Height="6" VerticalAlignment="Center">
                            <Border Background="#262626" CornerRadius="3"/>
                            <Border x:Name="WeekAllBar" Background="#4ade80" CornerRadius="3"
                                    HorizontalAlignment="Left" Width="0"/>
                        </Grid>
                        <Canvas x:Name="WeekAllMarkerCanvas" ClipToBounds="False">
                            <Grid x:Name="WeekAllMarker" Canvas.Left="0" Canvas.Top="-2"
                                  Visibility="Collapsed">
                                <Rectangle Width="2" Height="22" Fill="White" HorizontalAlignment="Center"/>
                                <Ellipse Width="5" Height="5" Fill="White" VerticalAlignment="Top"
                                         HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                                <Ellipse Width="5" Height="5" Fill="White" VerticalAlignment="Bottom"
                                         HorizontalAlignment="Center" Margin="0,0,0,-2"/>
                                <TextBlock x:Name="WeekAllMarkerLabel" Text="--%"
                                           FontSize="8" Foreground="White" FontWeight="Bold"
                                           Canvas.Top="-14" HorizontalAlignment="Center"/>
                            </Grid>
                        </Canvas>
                    </Grid>
                    <TextBlock Grid.Row="3" x:Name="WeekAllResetText" Text="Resets in --"
                               FontSize="10" Foreground="#888"/>
                </Grid>
            </Border>

            <!-- Sub Model -->
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" x:Name="SubModelTitle" Text="WEEKLY · SONNET"
                               Style="{StaticResource Sec}"/>
                    <TextBlock Grid.Row="1" x:Name="SubPctText" Text="0%" Style="{StaticResource Big}"
                               Margin="0,0,0,8"/>
                    <Grid Grid.Row="2" Height="18" VerticalAlignment="Center" Margin="0,0,0,6">
                        <Grid Height="6" VerticalAlignment="Center">
                            <Border Background="#262626" CornerRadius="3"/>
                            <Border x:Name="SubBar" Background="#4ade80" CornerRadius="3"
                                    HorizontalAlignment="Left" Width="0"/>
                        </Grid>
                        <Canvas x:Name="SubMarkerCanvas" ClipToBounds="False">
                            <Grid x:Name="SubMarker" Canvas.Left="0" Canvas.Top="-2"
                                  Visibility="Collapsed">
                                <Rectangle Width="2" Height="22" Fill="White" HorizontalAlignment="Center"/>
                                <Ellipse Width="5" Height="5" Fill="White" VerticalAlignment="Top"
                                         HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                                <Ellipse Width="5" Height="5" Fill="White" VerticalAlignment="Bottom"
                                         HorizontalAlignment="Center" Margin="0,0,0,-2"/>
                                <TextBlock x:Name="SubMarkerLabel" Text="--%"
                                           FontSize="8" Foreground="White" FontWeight="Bold"
                                           Canvas.Top="-14" HorizontalAlignment="Center"/>
                            </Grid>
                        </Canvas>
                    </Grid>
                    <TextBlock Grid.Row="3" x:Name="SubResetText" Text="Resets in --"
                               FontSize="10" Foreground="#888"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ DELTA CHART ═══ -->
        <Border Grid.Row="5" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="SESSION USAGE DELTA · REALTIME"
                           Style="{StaticResource Sec}"/>
                <Canvas x:Name="DeltaChartCanvas" Grid.Row="1"
                        SizeChanged="DeltaChartCanvas_SizeChanged" ClipToBounds="True"/>
                <TextBlock x:Name="DeltaEmptyText" Grid.Row="1"
                           Text="Collecting data... 0 snapshot(s) so far"
                           FontSize="11" Foreground="#888"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ═══ FOOTER ═══ -->
        <Grid Grid.Row="6" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="LastUpdateLabel" Grid.Column="0"
                       Text="Last update: --:--:--" FontSize="10" Foreground="#888"/>
            <TextBlock x:Name="VersionLabel" Grid.Column="1" Text="v1.0.0" FontSize="10" Foreground="#666"
                       HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="2" FontSize="10" Foreground="#888">
                made by <Run x:Name="CreditLink" Text="zitify" Foreground="#4ade80"
                             Cursor="Hand" TextDecorations="Underline"
                             MouseLeftButtonDown="CreditLink_Click"/>
            </TextBlock>
        </Grid>

        <!-- Hidden WebView2 for API calls (shares cookies with LoginWindow) -->
        <wv2:WebView2 x:Name="BgWebView" Width="1" Height="1"
                      HorizontalAlignment="Left" VerticalAlignment="Top"
                      Visibility="Collapsed" Grid.RowSpan="7"/>
    </Grid>
</Window>

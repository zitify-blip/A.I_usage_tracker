<Window x:Class="AIUsageTracker.Views.GeminiAccountManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gemini 계정 관리"
        Width="780" Height="520"
        Background="#0f0f0f"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <SolidColorBrush x:Key="TxtHighlight" Color="#f5f5f5"/>
        <SolidColorBrush x:Key="TxtSub" Color="#888888"/>

        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Background" Value="#262626"/>
            <Setter Property="Foreground" Value="#e8e8e8"/>
            <Setter Property="BorderBrush" Value="#2a2a2a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#333"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#1e1e1e"/>
            <Setter Property="BorderBrush" Value="#2a2a2a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style x:Key="Sec" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="Gemini 계정 관리"
                   FontSize="18" FontWeight="Bold" Foreground="{StaticResource TxtHighlight}"
                   Margin="0,0,0,12"/>

        <!-- Account list -->
        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="ACCOUNTS" Style="{StaticResource Sec}"/>
                <ListBox Grid.Row="1" x:Name="AccountList" Background="Transparent"
                         BorderThickness="0" Foreground="#e8e8e8"
                         SelectionChanged="AccountList_SelectionChanged">
                    <ListBox.Resources>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Padding" Value="6,8"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#2a3a2a"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#262626"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.Resources>
                </ListBox>
            </Grid>
        </Border>

        <!-- Editor panel -->
        <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource Card}">
            <Grid x:Name="EditorPanel">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Alias + Preview -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="ALIAS" Style="{StaticResource Sec}"/>
                    <TextBox Grid.Row="1" Grid.Column="0" x:Name="AliasBox"/>
                    <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal">
                        <TextBlock x:Name="KeyPreviewText" Text="--" Foreground="#888" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock x:Name="PrimaryBadge" Text="★ PRIMARY" FontSize="10" FontWeight="Bold"
                                   Foreground="#facc15" VerticalAlignment="Center"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Grid>

                <!-- Key rotation -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="KEY ROTATION (새 API Key 입력 후 교체)"
                               Style="{StaticResource Sec}"/>
                    <PasswordBox Grid.Row="1" Grid.Column="0" x:Name="NewKeyBox"/>
                    <Button Grid.Row="1" Grid.Column="2" Content="🔄 교체 및 검증"
                            Style="{StaticResource Btn}" Click="RotateKey_Click"/>
                </Grid>

                <!-- Budget -->
                <StackPanel Grid.Row="4">
                    <TextBlock Text="BUDGET (USD · 0 = 비활성)" Style="{StaticResource Sec}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="일간 예산($)"
                                   FontSize="10" Foreground="#aaa" Margin="0,4,0,2"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="월간 예산($)"
                                   FontSize="10" Foreground="#aaa" Margin="0,4,0,2"/>
                        <TextBlock Grid.Row="0" Grid.Column="4" Text="알림 임계치(%)"
                                   FontSize="10" Foreground="#aaa" Margin="0,4,0,2"/>
                        <TextBox Grid.Row="1" Grid.Column="0" x:Name="DailyBudgetBox"/>
                        <TextBox Grid.Row="1" Grid.Column="2" x:Name="MonthlyBudgetBox"/>
                        <TextBox Grid.Row="1" Grid.Column="4" x:Name="AlertThresholdBox"/>
                    </Grid>
                </StackPanel>

                <!-- Toggles -->
                <StackPanel Grid.Row="6" Orientation="Horizontal">
                    <CheckBox x:Name="PrimaryCheck" Content="Primary 계정으로 설정" Foreground="#e8e8e8"
                              VerticalContentAlignment="Center"/>
                    <CheckBox x:Name="ActiveCheck" Content="활성화" Foreground="#e8e8e8" Margin="24,0,0,0"
                              VerticalContentAlignment="Center"/>
                </StackPanel>

                <!-- Actions -->
                <Grid Grid.Row="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="🗑 삭제" Style="{StaticResource Btn}"
                            Click="Delete_Click" Background="#3a1a1a" BorderBrush="#f87171"/>
                    <TextBlock Grid.Column="1" x:Name="StatusLabel" Foreground="#888" FontSize="11"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <Button Grid.Column="2" Content="닫기" Style="{StaticResource Btn}" Click="Close_Click"/>
                    <Button Grid.Column="4" Content="💾 저장" Style="{StaticResource Btn}"
                            Click="Save_Click" Background="#1a3a1a" BorderBrush="#4ade80"/>
                </Grid>
            </Grid>
        </Border>

        <TextBlock Grid.Row="2" Grid.ColumnSpan="3"
                   Text="💡 계정 삭제 시 해당 계정의 사용 기록도 함께 삭제됩니다."
                   FontSize="10" Foreground="#aaa" Margin="0,10,0,0"/>
    </Grid>
</Window>

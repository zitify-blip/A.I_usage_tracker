<Window x:Class="AIUsageTracker.Views.GeminiAccountManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gemini 계정 관리"
        Width="780" Height="520"
        Background="{StaticResource BgBaseBrush}"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="Gemini 계정 관리"
                   FontSize="18" FontWeight="Bold" Foreground="{StaticResource TxtHighlightBrush}"
                   Margin="0,0,0,12"/>

        <!-- Account list -->
        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="ACCOUNTS" Style="{StaticResource Sec}"/>
                <ListBox Grid.Row="1" x:Name="AccountList"
                         SelectionChanged="AccountList_SelectionChanged"/>
            </Grid>
        </Border>

        <!-- Editor panel -->
        <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource Card}">
            <Grid x:Name="EditorPanel">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Alias + Preview -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="ALIAS" Style="{StaticResource Sec}"/>
                    <TextBox Grid.Row="1" Grid.Column="0" x:Name="AliasBox"/>
                    <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal">
                        <TextBlock x:Name="KeyPreviewText" Text="--" Foreground="{StaticResource TxtSubBrush}" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock x:Name="PrimaryBadge" Text="★ PRIMARY" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource AccentYellowBrush}" VerticalAlignment="Center"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Grid>

                <!-- Key rotation -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="KEY ROTATION (새 API Key 입력 후 교체)"
                               Style="{StaticResource Sec}"/>
                    <PasswordBox Grid.Row="1" Grid.Column="0" x:Name="NewKeyBox"/>
                    <Button Grid.Row="1" Grid.Column="2" Content="🔄 교체 및 검증"
                            Style="{StaticResource Btn}" Click="RotateKey_Click"/>
                </Grid>

                <!-- Budget -->
                <StackPanel Grid.Row="4">
                    <TextBlock Text="BUDGET (USD · 0 = 비활성)" Style="{StaticResource Sec}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="일간 예산($)"
                                   FontSize="10" Foreground="{StaticResource TxtHintBrush}" Margin="0,4,0,2"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="월간 예산($)"
                                   FontSize="10" Foreground="{StaticResource TxtHintBrush}" Margin="0,4,0,2"/>
                        <TextBlock Grid.Row="0" Grid.Column="4" Text="알림 임계치(%)"
                                   FontSize="10" Foreground="{StaticResource TxtHintBrush}" Margin="0,4,0,2"/>
                        <TextBox Grid.Row="1" Grid.Column="0" x:Name="DailyBudgetBox"/>
                        <TextBox Grid.Row="1" Grid.Column="2" x:Name="MonthlyBudgetBox"/>
                        <TextBox Grid.Row="1" Grid.Column="4" x:Name="AlertThresholdBox"/>
                    </Grid>
                </StackPanel>

                <!-- Toggles -->
                <StackPanel Grid.Row="6" Orientation="Horizontal">
                    <CheckBox x:Name="PrimaryCheck" Content="Primary 계정으로 설정"
                              VerticalContentAlignment="Center"/>
                    <CheckBox x:Name="ActiveCheck" Content="활성화" Margin="24,0,0,0"
                              VerticalContentAlignment="Center"/>
                </StackPanel>

                <!-- Actions -->
                <Grid Grid.Row="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="🗑 삭제" Style="{StaticResource BtnDanger}"
                            Click="Delete_Click"/>
                    <TextBlock Grid.Column="1" x:Name="StatusLabel" Foreground="{StaticResource TxtSubBrush}" FontSize="11"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <Button Grid.Column="2" Content="닫기" Style="{StaticResource Btn}" Click="Close_Click"/>
                    <Button Grid.Column="4" Content="💾 저장" Style="{StaticResource BtnPrimary}"
                            Click="Save_Click"/>
                </Grid>
            </Grid>
        </Border>

        <TextBlock Grid.Row="2" Grid.ColumnSpan="3"
                   Text="💡 계정 삭제 시 해당 계정의 사용 기록도 함께 삭제됩니다."
                   FontSize="10" Foreground="{StaticResource TxtHintBrush}" Margin="0,10,0,0"/>
    </Grid>
</Window>

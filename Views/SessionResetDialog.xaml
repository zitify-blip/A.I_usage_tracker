<Window x:Class="AIUsageTracker.Views.SessionResetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Claude 세션 리셋됨"
        Width="460" Height="280"
        Background="#0f0f0f"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Background" Value="#262626"/>
            <Setter Property="Foreground" Value="#e8e8e8"/>
            <Setter Property="BorderBrush" Value="#2a2a2a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🔄 새 세션 시작" FontSize="16" FontWeight="Bold"
                   Foreground="#f5f5f5"/>

        <TextBlock Grid.Row="2" FontSize="11" Foreground="#888" TextWrapping="Wrap">
            5시간 사용량 윈도가 리셋되었습니다. 메시지를 보내 새 세션을 시작합니다.
            <LineBreak/>
            <Run Foreground="#facc15">⚠ 자동 메시지 전송은 Claude.ai 의 사용 정책에 영향을 줄 수 있습니다. 본인 책임 하에 사용하세요.</Run>
        </TextBlock>

        <TextBlock Grid.Row="4" Text="보낼 메시지" FontSize="11" Foreground="#888"/>
        <TextBox Grid.Row="6" x:Name="MessageBox" Text="안녕"
                 FontSize="13" Padding="8,6" MinHeight="32"
                 Background="#1a1a1a" Foreground="#e8e8e8" BorderBrush="#2a2a2a"
                 AcceptsReturn="False"/>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="취소" Style="{StaticResource Btn}" Click="Cancel_Click"
                    Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="보내기" Style="{StaticResource Btn}" Click="Send_Click"
                    Background="#1a3a1a" BorderBrush="#4ade80" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>

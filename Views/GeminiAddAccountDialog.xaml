<Window x:Class="AIUsageTracker.Views.GeminiAddAccountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gemini 계정 추가"
        Width="480" Height="320"
        Background="{StaticResource BgBaseBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="새 Gemini 계정 추가" FontSize="16" FontWeight="Bold"
                   Foreground="{StaticResource TxtHighlightBrush}"/>

        <TextBlock Grid.Row="2" Text="별칭(Alias)" FontSize="11" Foreground="{StaticResource TxtSubBrush}"/>
        <TextBox Grid.Row="4" x:Name="AliasBox" Text="" ToolTip="예: work-main, personal-dev"/>

        <TextBlock Grid.Row="6" FontSize="11" Foreground="{StaticResource TxtSubBrush}">
            API Key  <Run Foreground="{StaticResource TxtHintBrush}" FontSize="10">(Google AI Studio에서 발급)</Run>
        </TextBlock>
        <PasswordBox Grid.Row="8" x:Name="ApiKeyBox"/>

        <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="취소" Style="{StaticResource Btn}" Click="Cancel_Click"
                    Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="추가 및 검증" Style="{StaticResource BtnPrimary}" Click="Ok_Click"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>

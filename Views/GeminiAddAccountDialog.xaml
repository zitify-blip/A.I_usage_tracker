<Window x:Class="AIUsageTracker.Views.GeminiAddAccountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gemini 계정 추가"
        Width="480" Height="320"
        Background="#0f0f0f"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Background" Value="#262626"/>
            <Setter Property="Foreground" Value="#e8e8e8"/>
            <Setter Property="BorderBrush" Value="#2a2a2a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="새 Gemini 계정 추가" FontSize="16" FontWeight="Bold"
                   Foreground="#f5f5f5"/>

        <TextBlock Grid.Row="2" Text="별칭(Alias)" FontSize="11" Foreground="#888"/>
        <TextBox Grid.Row="4" x:Name="AliasBox" Text="" ToolTip="예: work-main, personal-dev"/>

        <TextBlock Grid.Row="6" FontSize="11" Foreground="#888">
            API Key  <Run Foreground="#aaa" FontSize="10">(Google AI Studio에서 발급)</Run>
        </TextBlock>
        <PasswordBox Grid.Row="8" x:Name="ApiKeyBox"/>

        <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="취소" Style="{StaticResource Btn}" Click="Cancel_Click"
                    Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="추가 및 검증" Style="{StaticResource Btn}" Click="Ok_Click"
                    Background="#1a3a1a" BorderBrush="#4ade80" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="AIUsageTracker.Views.GeminiRelayHelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gemini Local Relay — 설정"
        Width="780" Height="820" MinWidth="580" MinHeight="560"
        Background="#0f0f0f"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Background" Value="#262626"/>
            <Setter Property="Foreground" Value="#e8e8e8"/>
            <Setter Property="BorderBrush" Value="#2a2a2a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#1e40af"/>
            <Setter Property="Foreground" Value="#f5f5f5"/>
            <Setter Property="BorderBrush" Value="#3b82f6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2563eb"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#7f1d1d"/>
            <Setter Property="BorderBrush" Value="#dc2626"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#991b1b"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#4ade80"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="CodeBox" TargetType="TextBox">
            <Setter Property="Background" Value="#0a0a0a"/>
            <Setter Property="Foreground" Value="#e8e8e8"/>
            <Setter Property="BorderBrush" Value="#1f1f1f"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas, 'Courier New'"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="CaretBrush" Value="#4ade80"/>
        </Style>

        <Style x:Key="ExpanderHeaderTB" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#d4d4d4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Text="📡 Gemini Local Relay" FontSize="18" FontWeight="Bold"
                       Foreground="#f5f5f5" VerticalAlignment="Center"/>
            <TextBlock x:Name="SubtitleText" Text="" FontSize="11" Foreground="#888"
                       Margin="12,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Info box -->
        <Border Grid.Row="2" Background="#0a1a0a" BorderBrush="#1a3a1a" BorderThickness="1"
                CornerRadius="6" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="💡" FontSize="14" Margin="0,0,8,0"
                           VerticalAlignment="Top"/>
                <StackPanel Grid.Column="1">
                    <TextBlock FontSize="12" Foreground="#e8e8e8" TextWrapping="Wrap">
                        <Run FontWeight="SemiBold">동작 방식:</Run>
                        <Run>다른 프로그램/SDK가 Gemini API 대신 이 트래커를 바라보게 설정하면, 트래커가 중계하면서 모든 호출의 토큰·비용을 자동 기록합니다.</Run>
                    </TextBlock>
                    <TextBlock FontSize="11" Foreground="#aaa" TextWrapping="Wrap" Margin="0,6,0,0">
                        <Run FontWeight="SemiBold" Foreground="#4ade80">Placeholder 키 규칙:</Run>
                        <Run>실제 API 키 대신</Run>
                        <Run FontFamily="Consolas" Foreground="#facc15">tracker-&lt;alias&gt;</Run>
                        <Run>를 사용합니다. 트래커가 저장된 실제 키로 치환해서 전송하므로, 외부 클라이언트에 진짜 키가 절대 노출되지 않습니다.</Run>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Auto-setup cards container -->
        <StackPanel Grid.Row="4">

        <!-- Env var auto-apply card -->
        <Border Background="#0a0f1c" BorderBrush="#1e40af" BorderThickness="1"
                CornerRadius="8" Padding="16,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="🎯 1단계 · 환경변수 자동 설정" FontSize="13" FontWeight="SemiBold"
                           Foreground="#60a5fa"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                           FontSize="11" Foreground="#9ca3af" TextWrapping="Wrap"
                           Margin="0,4,0,10">
                    <Run>환경변수 4개</Run>
                    <Run FontFamily="Consolas" Foreground="#cbd5e1">GOOGLE_API_KEY, GEMINI_API_KEY, GOOGLE_GENAI_BASE_URL, GOOGLE_GEMINI_BASE_URL</Run>
                    <Run>을 이 PC의 사용자 계정에 설정/제거합니다. 앞으로 새로 열리는 모든 터미널·IDE·스크립트에 자동 반영됩니다.</Run>
                </TextBlock>

                <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="StatusBadgeText" FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="PrimaryActionBtn" Content="⚡ 자동 설정"
                            Style="{StaticResource PrimaryBtn}"
                            Click="PrimaryAction_Click" MinWidth="140"/>
                    <Button x:Name="RevertBtn" Content="🔄 되돌리기"
                            Style="{StaticResource DangerBtn}"
                            Click="Revert_Click" MinWidth="120" Margin="8,0,0,0"
                            Visibility="Collapsed"/>
                </StackPanel>

                <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                           FontSize="10" Foreground="#71717a" TextWrapping="Wrap"
                           Margin="0,10,0,0">
                    <Run>ⓘ 이미 열려 있는 터미널/IDE는 재시작해야 새 값을 인식합니다. 기존 사용자 값이 있으면 자동으로 백업되고, 되돌리기 시 복원됩니다.</Run>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Claude CLI rule card -->
        <Border Background="#1a0f1c" BorderBrush="#7c3aed" BorderThickness="1"
                CornerRadius="8" Padding="16,14" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="🤖 2단계 · Claude CLI 연동 규칙 설치" FontSize="13" FontWeight="SemiBold"
                           Foreground="#a78bfa"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                           FontSize="11" Foreground="#9ca3af" TextWrapping="Wrap"
                           Margin="0,4,0,10">
                    <Run>사용자 프로필의</Run>
                    <Run FontFamily="Consolas" Foreground="#cbd5e1">~/.claude/CLAUDE.md</Run>
                    <Run>에 규칙 블록을 추가합니다. 설치 후에는 Claude CLI 세션에서</Run>
                    <Run FontStyle="Italic" Foreground="#e8e8e8">"재미나이로 X해줘"</Run>
                    <Run>라고 말하면 자동으로 Gemini 2.5 Flash/Pro를 호출하고, 응답을 받아 작업을 이어갑니다.</Run>
                </TextBlock>

                <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="RuleStatusBadgeText" FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="InstallRuleBtn" Content="⚡ 규칙 설치"
                            Style="{StaticResource PrimaryBtn}"
                            Click="InstallRule_Click" MinWidth="140"
                            Background="#5b21b6" BorderBrush="#8b5cf6"/>
                    <Button x:Name="RemoveRuleBtn" Content="🔄 제거"
                            Style="{StaticResource DangerBtn}"
                            Click="RemoveRule_Click" MinWidth="120" Margin="8,0,0,0"
                            Visibility="Collapsed"/>
                </StackPanel>

                <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                           FontSize="10" Foreground="#71717a" TextWrapping="Wrap"
                           Margin="0,10,0,0">
                    <Run>ⓘ 이미 실행 중인 Claude CLI 세션은 변경을 인식하지 않습니다. 세션 종료 후 새로 시작한 claude 부터 규칙이 적용됩니다. 사용자가 수동 편집한 다른 부분은 건드리지 않습니다.</Run>
                </TextBlock>
            </Grid>
        </Border>

        </StackPanel>

        <!-- Advanced (expanders) -->
        <ScrollViewer Grid.Row="6" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <Expander Margin="0,0,0,10" IsExpanded="False" Foreground="#d4d4d4">
                    <Expander.Header>
                        <TextBlock Text="📋 수동 설정 스니펫 (자동 설정이 실패하거나 다른 계정에 적용하려면)"
                                   Style="{StaticResource ExpanderHeaderTB}"/>
                    </Expander.Header>
                    <StackPanel Margin="0,10,0,0">

                        <TextBlock Text="BASE URL · API KEY" Style="{StaticResource SecTitle}"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="BaseUrlBox" Style="{StaticResource CodeBox}"/>
                            <Button Grid.Column="2" Content="📋 복사" Style="{StaticResource Btn}"
                                    Click="CopyBaseUrl_Click" MinWidth="70"/>
                        </Grid>

                        <TextBlock Text="환경변수 · PowerShell (현재 셸 + 영구 한 번에)" Style="{StaticResource SecTitle}"/>
                        <TextBlock Text="이 스니펫을 PowerShell에 그대로 붙여넣으면, 지금 이 셸에 즉시 적용되고 동시에 사용자 환경변수에도 저장됩니다."
                                   FontSize="10" Foreground="#888" TextWrapping="Wrap" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="EnvBox" Style="{StaticResource CodeBox}"
                                     Height="150"/>
                            <Button Grid.Column="2" Content="📋 복사" Style="{StaticResource Btn}"
                                    Click="CopyEnv_Click" MinWidth="70" VerticalAlignment="Top"/>
                        </Grid>

                        <TextBlock Text="환경변수 · cmd.exe (set + setx 쌍)" Style="{StaticResource SecTitle}"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="EnvCmdBox" Style="{StaticResource CodeBox}"
                                     Height="130"/>
                            <Button Grid.Column="2" Content="📋 복사" Style="{StaticResource Btn}"
                                    Click="CopyEnvCmd_Click" MinWidth="70" VerticalAlignment="Top"/>
                        </Grid>

                    </StackPanel>
                </Expander>

                <Expander Margin="0,0,0,4" IsExpanded="False" Foreground="#d4d4d4">
                    <Expander.Header>
                        <TextBlock Text="💻 내 코드에서 사용하는 예시 (cURL / Python / Node.js)"
                                   Style="{StaticResource ExpanderHeaderTB}"/>
                    </Expander.Header>
                    <StackPanel Margin="0,10,0,0">

                        <TextBlock Text="cURL 예제" Style="{StaticResource SecTitle}"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="CurlBox" Style="{StaticResource CodeBox}"
                                     Height="90"/>
                            <Button Grid.Column="2" Content="📋 복사" Style="{StaticResource Btn}"
                                    Click="CopyCurl_Click" MinWidth="70" VerticalAlignment="Top"/>
                        </Grid>

                        <TextBlock Text="Python (google-generativeai)" Style="{StaticResource SecTitle}"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="PyLegacyBox" Style="{StaticResource CodeBox}"
                                     Height="130"/>
                            <Button Grid.Column="2" Content="📋 복사" Style="{StaticResource Btn}"
                                    Click="CopyPyLegacy_Click" MinWidth="70" VerticalAlignment="Top"/>
                        </Grid>

                        <TextBlock Text="Python (google-genai · 최신 통합 SDK)" Style="{StaticResource SecTitle}"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="PyNewBox" Style="{StaticResource CodeBox}"
                                     Height="110"/>
                            <Button Grid.Column="2" Content="📋 복사" Style="{StaticResource Btn}"
                                    Click="CopyPyNew_Click" MinWidth="70" VerticalAlignment="Top"/>
                        </Grid>

                        <TextBlock Text="Node.js (@google/generative-ai)" Style="{StaticResource SecTitle}"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="NodeBox" Style="{StaticResource CodeBox}"
                                     Height="110"/>
                            <Button Grid.Column="2" Content="📋 복사" Style="{StaticResource Btn}"
                                    Click="CopyNode_Click" MinWidth="70" VerticalAlignment="Top"/>
                        </Grid>

                    </StackPanel>
                </Expander>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="StatusText" Text=""
                       FontSize="11" Foreground="#4ade80" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="닫기" Style="{StaticResource Btn}"
                    Click="Close_Click" MinWidth="70" IsCancel="True"/>
        </Grid>
    </Grid>
</Window>

<Window x:Class="AIUsageTracker.Views.GrokAddAccountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Grok (xAI) API 계정 추가"
        Width="480" Height="340"
        Background="{StaticResource BgBaseBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="새 Grok (xAI) 계정 추가" FontSize="16" FontWeight="Bold"
                   Foreground="{StaticResource TxtHighlightBrush}"/>

        <TextBlock Grid.Row="2" Text="별칭(Alias)" FontSize="11" Foreground="{StaticResource TxtSubBrush}"/>
        <TextBox Grid.Row="4" x:Name="AliasBox" Text="" ToolTip="예: work, personal"/>

        <TextBlock Grid.Row="6" FontSize="11" Foreground="{StaticResource TxtSubBrush}">
            xAI API Key  <Run Foreground="{StaticResource TxtHintBrush}" FontSize="10">(xai-* — console.x.ai → API Keys)</Run>
        </TextBlock>
        <PasswordBox Grid.Row="8" x:Name="ApiKeyBox"/>

        <TextBlock Grid.Row="10" FontSize="10" Foreground="{StaticResource AccentYellowBrush}" TextWrapping="Wrap">
            ⚠ xAI는 조직 사용량 조회 엔드포인트를 제공하지 않으므로 키 정보(허용 모델, 활성 상태)만 표시됩니다. 사용량은 console.x.ai에서 확인하세요.
        </TextBlock>

        <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="취소" Style="{StaticResource Btn}" Click="Cancel_Click"
                    Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="추가 및 검증" Style="{StaticResource BtnPrimary}" Click="Ok_Click"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="AIUsageTracker.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Claude Login"
        Width="500" Height="700"
        WindowStartupLocation="CenterOwner"
        Background="#0f0f0f"
        ResizeMode="CanResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1a1a1a" Padding="16,10">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Log in to Claude" FontSize="15" FontWeight="Bold" Foreground="#f5f5f5"/>
                    <TextBlock Text="로그인 후 아래 '로그인 완료' 버튼을 클릭하세요." FontSize="11" Foreground="#888" Margin="0,3,0,0"/>
                </StackPanel>
                <TextBlock x:Name="StatusText" Text="" FontSize="11" Foreground="#facc15"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- WebView2 for login -->
        <wv2:WebView2 x:Name="LoginWebView" Grid.Row="1"/>

        <!-- Bottom bar -->
        <Border Grid.Row="2" Background="#1a1a1a" Padding="12,8">
            <Grid>
                <Button x:Name="DoneBtn" Content="✓ 로그인 완료" Click="DoneBtn_Click"
                        HorizontalAlignment="Right" Cursor="Hand"
                        FontSize="13" FontWeight="Bold" Foreground="White" Padding="24,8"
                        BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#4ade80" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#6ee7a0"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="취소" Click="CancelBtn_Click"
                        HorizontalAlignment="Left" Cursor="Hand"
                        FontSize="12" Foreground="#bbb" Padding="16,8"
                        Background="#262626" BorderBrush="#333" BorderThickness="1">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#262626" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}" BorderBrush="#333" BorderThickness="1">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#333"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>

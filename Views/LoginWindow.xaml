<Window x:Class="AIUsageTracker.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Claude Login"
        Width="500" Height="700"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBaseBrush}"
        ResizeMode="CanResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource BgInputBrush}" Padding="16,10">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Log in to Claude" FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource TxtHighlightBrush}"/>
                    <TextBlock Text="로그인 후 아래 '로그인 완료' 버튼을 클릭하세요." FontSize="11"
                               Foreground="{StaticResource TxtSubBrush}" Margin="0,3,0,0"/>
                </StackPanel>
                <TextBlock x:Name="StatusText" Text="" FontSize="11" Foreground="{StaticResource AccentYellowBrush}"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- WebView2 for login -->
        <wv2:WebView2 x:Name="LoginWebView" Grid.Row="1"/>

        <!-- Bottom bar -->
        <Border Grid.Row="2" Background="{StaticResource BgInputBrush}" Padding="12,8">
            <Grid>
                <Button x:Name="DoneBtn" Content="✓ 로그인 완료" Click="DoneBtn_Click"
                        Style="{StaticResource BtnPrimary}"
                        HorizontalAlignment="Right"
                        FontSize="13" Padding="24,8"/>
                <Button Content="취소" Click="CancelBtn_Click"
                        Style="{StaticResource Btn}"
                        HorizontalAlignment="Left"
                        Padding="16,8"
                        IsCancel="True"/>
            </Grid>
        </Border>
    </Grid>
</Window>
